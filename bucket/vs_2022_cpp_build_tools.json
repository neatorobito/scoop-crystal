{
    "version": "17.0",
    "description": "Visual Studio 2022 C++ Build Tools",
    "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe",
    "hash": "F6EA321FA31185FAA9892F90BF2FB179AF67E4982DEA349027F120CDDB79DDB8",
    "installer": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--add",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--add",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ],
        "keep": true
    },
    "uninstaller": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--remove",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--remove",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ]
    }
}
