{
    "version": "17.0",
    "description": "Visual Studio 2022 C++ Build Tools",
    "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe",
    "hash": "CFBE96493247C4C4280EA7E765AD427F89A76A1507B1144C7EDB319069369387",
    "installer": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--add",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--add",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ],
        "keep": true
    },
    "uninstaller": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--remove",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--remove",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ]
    }
}
