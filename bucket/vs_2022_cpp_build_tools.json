{
    "version": "17.0",
    "description": "Visual Studio 2022 C++ Build Tools",
    "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe",
    "hash": "741736B84677327922FBFFB54A6938931CDFD0E1F0ECF66662C9BEB5F08FDF3D",
    "installer": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--add",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--add",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ],
        "keep": true
    },
    "uninstaller": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--remove",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--remove",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ]
    }
}
