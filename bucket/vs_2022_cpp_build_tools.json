{
    "version": "17.0",
    "description": "Visual Studio 2022 C++ Build Tools",
    "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe",
    "hash": "2C18F00378D907EADF7677DFE0458CDEA873C1A8F56184466DA9FFEF7F210878",
    "installer": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--add",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--add",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ],
        "keep": true
    },
    "uninstaller": {
        "file": "vs_BuildTools.exe",
        "args": [
            "--passive",
            "--norestart",
            "--wait",
            "--remove",
            "Microsoft.VisualStudio.Workload.VCTools",
            "--remove",
            "Microsoft.VisualStudio.Component.VC.ATL",
            "--includeRecommended"
        ]
    }
}
